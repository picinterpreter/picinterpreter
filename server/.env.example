# 图语家 API 代理配置
# 复制为 .env 并填写实际值

# ── LLM（AI 句子生成）────────────────────────────────────────────────────── #

# 必填：LLM API Key
LLM_API_KEY=sk-your-key-here

# 选填：API 基础地址（默认 OpenAI，可换 Qwen/DeepSeek/豆包方舟）
# OpenAI:      https://api.openai.com/v1
# DeepSeek:    https://api.deepseek.com/v1
# Qwen:        https://dashscope.aliyuncs.com/compatible-mode/v1
# 豆包/方舟:   https://ark.cn-beijing.volces.com/api/v3
LLM_BASE_URL=https://api.openai.com/v1

# 选填：默认模型（豆包方舟用 doubao-lite-32k）
LLM_MODEL=gpt-4o-mini

# 选填：代理服务端口
PORT=3001

# 选填：允许的前端来源（生产部署时改为实际域名）
ALLOWED_ORIGIN=http://localhost:5173

# ── 豆包语音识别（ASR）───────────────────────────────────────────────────── #
# 申请地址：https://console.volcengine.com/speech/service/asr
# 注意：与火山方舟 API Key 不同，需在豆包语音控制台单独申请 APP ID 和 Access Token

# 必填（启用 ASR 时）：豆包语音 APP ID
DOUBAO_ASR_APP_ID=

# 必填（启用 ASR 时）：豆包语音 Access Token
DOUBAO_ASR_ACCESS_TOKEN=

# 选填：识别模型资源 ID
# 豆包流式识别模型 1.0（小时计费）：volc.bigasr.sauc.duration
# 豆包流式识别模型 1.0（并发）：     volc.bigasr.sauc.concurrent
# 豆包流式识别模型 2.0（小时计费）：volc.seedasr.sauc.duration
DOUBAO_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
